generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
}

enum League {
  GREEN
  BLUE
}

enum TrackDifficulty {
  EASY
  MEDIUM
  HARD
}

enum CompletionResult {
  FIRST_TRY
  RETRY
}

model User {
  id              String            @id @default(cuid())
  nickname        String            @unique
  gender          Gender
  league          League            @default(GREEN)
  points          Int               @default(0)
  avatarData      Bytes?
  avatarMimeType  String?
  avatarUpdatedAt DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  completions     TrackCompletion[]
  ratings         TrackRating[]
  leagueChanges   LeagueChange[]

  @@index([league, points])
  @@map("users")
}

model Track {
  id          String            @id @default(cuid())
  slug        String            @unique
  order       Int               @unique
  name        String
  description String
  difficulty  TrackDifficulty
  points      Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  completions TrackCompletion[]
  ratings     TrackRating[]

  @@map("tracks")
}

model TrackCompletion {
  id            String           @id @default(cuid())
  userId        String
  trackId       String
  result        CompletionResult
  awardedPoints Int
  completedAt   DateTime         @default(now())
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  track         Track            @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId, completedAt])
  @@map("track_completions")
}

model TrackRating {
  id        String   @id @default(cuid())
  userId    String
  trackId   String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@map("track_ratings")
}

model LeagueChange {
  id         String   @id @default(cuid())
  userId     String
  fromLeague League
  toLeague   League
  rank       Int
  changedAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
  @@map("league_changes")
}
